CWA_API_KEY=your-cwa-api-key-here

# External Redis server (CWA / NLSC cache, 3h TTL; optional but recommended)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Vite dev proxy target (optional; default https://weather-map.test for Herd / Lerd)
# Fallback only (php -S, Docker, etc.): DEV_API_PROXY_TARGET=http://127.0.0.1:8080
