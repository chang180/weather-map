{
  "name": "weather-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && npm run sync-public",
    "sync-public": "cp dist/index.html public/ && rm -rf public/assets && cp -r dist/assets public/",
    "build:pages": "VITE_BASE_PATH=/weather-map/ vite build",
    "preview": "vite preview",
    "preview:pages": "npm run build:pages && vite preview --base /weather-map/",
    "deploy": "npm run build:pages && gh-pages -d dist"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "leaflet.fullscreen": "^3.0.2",
    "vue": "^3.5.35",
    "vue-leaflet": "^0.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "gh-pages": "^6.3.0",
    "leaflet": "^1.9.4",
    "vite": "^6.0.0"
  }
}
