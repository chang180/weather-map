{
  "name": "weather-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && npm run sync-public",
    "sync-public": "cp dist/index.html public/ && rm -rf public/assets && cp -r dist/assets public/",
    "build:pages": "VITE_BASE_PATH=/weather-map/ vite build",
    "preview": "vite preview",
    "preview:pages": "npm run build:pages && vite preview --base /weather-map/",
    "deploy": "npm run build:pages && gh-pages -d dist",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "leaflet": "^1.9.4",
    "leaflet.fullscreen": "^5.3.1",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "gh-pages": "^6.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.3"
  }
}
